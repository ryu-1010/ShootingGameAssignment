# --- OSごとの不要ファイル ---
# Macで勝手に作られる
.DS_Store
# Windowsで勝手に作られる
Thumbs.db


# --- Visual Studio関連 ---
# VSの設定やキャッシュ類（自動生成されるので不要）
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db


# --- Rider関連 ---
# JetBrains Riderの設定（個人環境用なので除外）
.idea/
*.sln.iml


# --- Unity関連 ---
# Unityが自動生成するキャッシュやビルド系（除外推奨）
Library/
Temp/
Obj/
Build/
Builds/
Logs/
MemoryCaptures/


# --- Unity Asset Store ---
# アセットストアからDLしたパッケージ（不要）
*.unitypackage


# --- 自動生成系ファイル ---
# 各種プラットフォームのビルド成果物や自動生成ファイル
ExportedObj/
*.apk
*.aab
*.xcworkspace
*.xcuserdata/
*.gradle
*.aar


# --- ユーザー固有設定 ---
# ユーザー環境依存ファイル（他人に不要）
UserSettings/


# --- その他 ---
# Unityのsysinfo出力
sysinfo.txt
# クラッシュログ
.crash/
